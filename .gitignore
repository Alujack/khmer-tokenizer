# Rust build artifacts
/target
/py/target
/wasm/target
**/*.rs.bk

# wasm-pack output (wasm/ bindings) — generated, published to npm, never committed
/wasm/pkg*

# Python build/test artifacts (py/ bindings)
__pycache__/
.pytest_cache/
*.egg-info/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Working documents not meant for the repo
docs/*.docx

# Downloaded corpora — CC BY-NC-SA (khPOS etc.), evaluation-only, never bundled
/data/